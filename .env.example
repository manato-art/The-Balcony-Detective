# ベランダ探偵 — イラスト生成用（tools/gen-art.mjs が読む）
# このファイルをコピーして .env を作り、実キーを入れてください（.env はコミットされません）。
#   cp .env.example .env  →  .env の OPENAI_API_KEY を書き換え

# OpenAI gpt-image-2 のAPIキー（必須）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 任意: 画質 low|medium|high|auto（既定 low＝最速・最安。スタイルテストは low 推奨）
OPENAI_IMAGE_QUALITY=low

# 任意: 同時生成数（既定 3。429が出るなら下げる）
GEN_CONCURRENCY=3
